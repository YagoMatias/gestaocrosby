{
  "name": "api-gestao-crosby",
  "version": "2.0.0",
  "description": "API refatorada para sistema de gestão Crosby",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "bash start.sh",
    "postinstall": "npx puppeteer browsers install chrome",
    "dev": "cross-env NODE_ENV=development nodemon index.js",
    "test": "cross-env NODE_ENV=test jest",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "security:audit": "npm audit --audit-level=moderate",
    "db:check": "node -e \"import('./config/database.js').then(db => db.default.query('SELECT 1').then(() => console.log('✅ Database connected')).catch(e => console.error('❌ Database error:', e)))\"",
    "extratos:caixa": "node scripts/run-caixa.js",
    "extratos:itau": "node scripts/run-itau.js",
    "extratos:bb": "node scripts/run-bb.js",
    "extratos:sicredi": "node scripts/run-sicredi.js",
    "extratos:bnb": "node scripts/run-bnb.js",
    "extratos:santander": "node scripts/run-santander.js",
    "extratos:unicred": "node scripts/run-unicred.js",
    "extratos:bradesco": "node scripts/run-bradesco.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.6.8",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.2.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.0",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.11.3",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "api",
    "express",
    "gestao",
    "crosby",
    "postgresql",
    "jwt"
  ],
  "author": "Sistema Crosby",
  "license": "Private",
  "repository": {
    "type": "git",
    "url": "."
  }
}
