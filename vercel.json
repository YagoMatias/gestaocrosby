{
  "redirects": [
    {
      "source": "/((?!vagas).*)",
      "has": [{ "type": "host", "value": "vagas.crosbyoficial.com.br" }],
      "destination": "https://crosbyoficial.com.br",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://apigestaocrosby-bw2v.onrender.com/api/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
