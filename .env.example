# ─── Supabase ────────────────────────────────────────────────────────────────
# URL do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Chave pública (anon) — segura para o frontend (RLS protege)
VITE_SUPABASE_ANON_KEY=eyJhbGc...
# Chave de service_role — ATENÇÃO: NUNCA deve estar exposta no frontend.
# Idealmente todas as operações administrativas devem rodar no backend.
# Esta variável permanece aqui apenas enquanto o frontend ainda usa supabaseAdmin.
VITE_SUPABASE_SERVICE_KEY=eyJhbGc...

# ─── Backend API ─────────────────────────────────────────────────────────────
# Override opcional. Em DEV sem override usa window.location.origin (proxy Vite).
# Em PROD sem override usa apigestaocrosby-bw2v.onrender.com.
VITE_API_BASE_URL=http://localhost:4100

# URL alternativa usada por alguns hooks/páginas (CrosbyBot, Widgets)
VITE_API_URL=http://localhost:4100

# Chave de API consumida pelo backend (header x-api-key)
VITE_API_KEY=

# Token Bearer para chamadas diretas à API TOTVS (services/fiscalMovementService.js)
VITE_TOTVS_API_TOKEN=
