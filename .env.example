# Frontend (Vite) — copie para .env.local e ajuste conforme necessário.
# .env.local é ignorado pelo git (vide .gitignore: .env).

# Override da base da API. Quando vazio:
#  - DEV: usa window.location.origin (proxy do Vite: /api → http://localhost:4001)
#  - PROD: usa https://apigestaocrosby-bw2v.onrender.com
# Defina explicitamente quando quiser apontar dev para outro backend, p.ex.:
# VITE_API_BASE_URL=http://localhost:4001
VITE_API_BASE_URL=
